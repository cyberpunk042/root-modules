# /etc/systemd/network/30-ghostproxy-bridge.netdev
# root-modules transparent L2 bridge interface definition.
# Deployed by $HOME/install.sh op_install_network_bridge (T013 — systemd-networkd).
#
# Bridge name fixed: gpbr0 (root-modules bridge 0). Members assigned by
# matching .network files (see 30-ghostproxy-bridge.network).

[NetDev]
Name=gpbr0
Kind=bridge
Description=root-modules transparent L2 IPS bridge

[Bridge]
# Disable STP — passive bridge, no spanning tree needed for IPS pass-through
STP=no
# Forward delay 0 — start forwarding immediately
ForwardDelaySec=0
# Hello time minimal (passive bridge)
HelloTimeSec=2
# Max age minimal
MaxAgeSec=20
# Default priority
Priority=32768
